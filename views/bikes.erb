<h1>Hobby Bikes Catalog</h1>
<% @bikes.each do |bike| %>

<div>
    <h2>
        <a href="/bikes/<%= bike['id'] %>">
        <%= bike['name'] %>
        </a>
    </h2>
    <p><%= bike['descrption'] %></p>
    <p>Price: $<%= bike['price'] %></p>
    <p>In stock: <%= bike['inventory'] %></p>
</div>

<hr>
<% end %>