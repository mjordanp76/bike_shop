<h2>Your Cart</h2>

<% if @items.ntuples == 0 %>

  <p>Your cart is empty.</p>

<% else %>

    <% total = 0 %>


    <% @items.each do |item| %>

    <% subtotal =
       item['price'].to_f *
       item['quantity'].to_i %>

    <% total += subtotal %>

    <div>

        <h3><%= item['name'] %></h3>

        <p>
        Quantity: <%= item['quantity'] %>
        </p>

        <p>
        Price: $<%= item['price'] %>
        </p>

        <p>
        Subtotal: $<%= subtotal.round(2) %>
        </p>

        <!-- remove button -->
        <form method="post" action="/cart/remove/<%= item['id'] %>">
            <button type="submit">
                Remove
            </button>
        </form>

    </div>

    <hr>

    <% end %>

    <h3>
        Total: $<%= total.round(2) %>
    </h3>

<% end %>